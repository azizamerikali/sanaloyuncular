<mvc:View controllerName="com.openui5.webdb.controller.admin.AdminMembers"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core"
	xmlns:form="sap.ui.layout.form" xmlns:u="sap.ui.unified"
	xmlns:f="sap.f" xmlns:cssgrid="sap.ui.layout.cssgrid">

	<Page id="adminMembersPage" title="{i18n>adminMembers}" showNavButton="false" class="sapUiContentPadding">
		<headerContent>
			<SearchField id="memberSearch" placeholder="{i18n>searchMembers}"
				liveChange=".onSearchMembers" width="auto" />
			<Button text="{i18n>addNewMember}" icon="sap-icon://add" type="Emphasized" press=".onOpenAddMember" class="sapUiSmallMarginBegin" />
		</headerContent>
		<content>
			<f:GridList id="adminMembersGrid" items="{membersData>/members}"
				noDataText="{i18n>noMembers}"
				growing="true" growingThreshold="20"
				showSeparators="None"
				class="soMemberGrid sapUiNoContentPadding">
				<f:customLayout>
					<cssgrid:GridBoxLayout boxMinWidth="280px" />
				</f:customLayout>
				<f:GridListItem type="Active" press=".onMemberPress">
					<VBox class="soMemberCard">
						<HBox justifyContent="SpaceBetween" alignItems="Start">
							<HBox alignItems="Center" class="sapUiSmallMarginBottom">
								<Avatar
									src="{membersData>profilePicture}"
									initials="{membersData>initials}"
									displaySize="M"
									displayShape="Circle"
									fallbackIcon="sap-icon://person-placeholder"
									class="sapUiSmallMarginEnd" />
								<VBox>
									<Title text="{membersData>firstName} {membersData>lastName}"
										level="H5" class="soMemberCardName" />
									<Text text="{membersData>email}" class="soMemberCardEmail" />
									<Text text="{membersData>city}" class="soMemberCardEmail" />
								</VBox>
							</HBox>
							<ObjectStatus text="{membersData>statusText}" state="{membersData>statusState}" />
						</HBox>
						<core:HTML content="&lt;hr class='soCardDivider'/&gt;" />
						<HBox justifyContent="SpaceBetween" alignItems="Center">
							<Text text="{membersData>createdAtFormatted}" class="soMemberCardEmail" />
							<HBox alignItems="Center">
								<Switch state="{= ${membersData>status} === 'active'}"
									type="AcceptReject"
									change=".onToggleStatus"
									tooltip="{i18n>status}"
									class="sapUiTinyMarginEnd" />
								<Button icon="sap-icon://delete" type="Reject"
									press=".onDeleteMember" tooltip="{i18n>delete}"
									class="sapUiTinyMarginBegin" />
							</HBox>
						</HBox>
					</VBox>
				</f:GridListItem>
			</f:GridList>
		</content>
		<dependents>
			<Dialog id="addMemberDialog" title="{i18n>addNewMember}" contentWidth="650px" verticalScrolling="true" stretch="{device>/system/phone}">
				<content>
					<form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12">
						<form:content>
							<Label text="{i18n>firstName}" required="true" />
							<Input value="{newMember>/firstName}" liveChange=".onNameChange" />
							<Label text="{i18n>lastName}" required="true" />
							<Input value="{newMember>/lastName}" liveChange=".onNameChange" />
							<Label text="{i18n>email}" required="true" />
							<Input value="{newMember>/email}" type="Email" />
							<Label text="{i18n>password}" required="true" />
							<Input value="{newMember>/password}" />
							<Label text="{i18n>phone}" required="true" />
							<Input value="{newMember>/phone}" type="Tel" />

							<Label text="{i18n>city}" required="true" />
							<ComboBox items="{cities>/}" selectedKey="{newMember>/city}">
								<core:Item key="{cities>key}" text="{cities>name}" />
							</ComboBox>

							<Label text="{i18n>birthDate}" required="true" />
							<DatePicker id="dpBirthDate" displayFormat="dd.MM.yyyy" valueFormat="yyyy-MM-dd" value="{newMember>/birthDate}" change=".onBirthDateChange" />

							<Label text="{i18n>parentName}" required="{newMember>/isUnder18}" visible="{newMember>/isUnder18}" />
							<Input id="inParentName" value="{newMember>/parentName}" visible="{newMember>/isUnder18}" liveChange=".onParentNameChange" />

							<Label text="{i18n>consentDoc}" required="{newMember>/isUnder18}" visible="{newMember>/isUnder18}" />
							<u:FileUploader id="fuConsent" width="100%" placeholder="{i18n>selectDocumentToUpload}" change=".onConsentFileChange" visible="{newMember>/isUnder18}" />

							<Label text="{i18n>ibanHolder}" required="true" />
							<ComboBox id="cbIbanHolder" selectedKey="{newMember>/ibanHolder}" items="{newMember>/ibanHolderList}">
								<core:Item key="{newMember>name}" text="{newMember>name}" />
							</ComboBox>

							<Label text="{i18n>iban}" required="true" />
							<Input id="inIban" value="{newMember>/iban}" placeholder="..." liveChange=".onIbanChange" valueState="{newMember>/ibanState}" valueStateText="{newMember>/ibanStateText}" />

							<Label text="{i18n>actingTraining}" />
							<TextArea value="{newMember>/actingTraining}" rows="2" />
							<Label text="{i18n>actingExperience}" />
							<TextArea value="{newMember>/actingExperience}" rows="2" />

							<Label text="{i18n>status}" />
							<Select selectedKey="{newMember>/status}" width="100%">
								<core:Item key="active" text="{i18n>active}" />
								<core:Item key="pending" text="{i18n>pendingApproval}" />
							</Select>
						</form:content>
					</form:SimpleForm>
				</content>
				<buttons>
					<Button text="{i18n>save}" type="Emphasized" press=".onSaveNewMember" />
					<Button text="{i18n>cancel}" press=".onCancelAddMember" />
				</buttons>
			</Dialog>
		</dependents>
	</Page>
</mvc:View>
