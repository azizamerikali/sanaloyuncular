<mvc:View controllerName="com.openui5.webdb.controller.admin.AdminDashboard"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core">

	<Page id="adminDashboardPage" title="{i18n>adminDashboardTitle}" showNavButton="false">
		<content>
			<VBox class="sapUiSmallMargin">
				<Title text="{i18n>adminPanelTitle}" level="H2" titleStyle="H4" class="sapUiMediumMarginBottom" />

				<!-- KPI Tiles Row 1 -->
				<FlexBox wrap="Wrap" class="sapUiSmallMarginBottom">
					<GenericTile
						header="{i18n>members}"
						subheader="{adminData>/pendingCount} {i18n>pendingCountSuffix}"
						class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom"
						press=".onNavToMembers">
						<TileContent>
							<NumericContent
								value="{adminData>/memberCount}"
								icon="sap-icon://group"
								valueColor="Good" />
						</TileContent>
					</GenericTile>
					<GenericTile
						header="{i18n>projects}"
						class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom"
						press=".onNavToProjects">
						<TileContent>
							<NumericContent
								value="{adminData>/projectCount}"
								icon="sap-icon://project-definition-triangle-2"
								valueColor="Neutral" />
						</TileContent>
					</GenericTile>
					<GenericTile
						header="{i18n>payments}"
						subheader="{adminData>/unpaidTotal} {i18n>unpaidSuffix}"
						class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom"
						press=".onNavToPayments">
						<TileContent>
							<NumericContent
								value="{adminData>/totalAmount}"
								truncateValueTo="15"
								icon="sap-icon://money-bills"
								valueColor="Critical" />
						</TileContent>
					</GenericTile>
				</FlexBox>

				<!-- KPI Tiles Row 2 -->
				<FlexBox wrap="Wrap" class="sapUiSmallMarginBottom">
					<GenericTile
						header="{i18n>media}"
						class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom"
						press=".onNavToMedia">
						<TileContent>
							<NumericContent
								value="{adminData>/mediaCount}"
								icon="sap-icon://camera"
								valueColor="Neutral" />
						</TileContent>
					</GenericTile>
					<GenericTile
						header="{i18n>clients}"
						class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom"
						press=".onNavToClients">
						<TileContent>
							<NumericContent
								value="{adminData>/clientCount}"
								icon="sap-icon://customer"
								valueColor="Neutral" />
						</TileContent>
					</GenericTile>
					<GenericTile
						header="{i18n>totalPaymentsDashboard}"
						class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom"
						press=".onNavToPayments">
						<TileContent>
							<NumericContent
								value="{adminData>/totalPaymentCount}"
								icon="sap-icon://receipt"
								valueColor="Good" />
						</TileContent>
					</GenericTile>
				</FlexBox>

				<!-- Pending Members Table -->
				<Panel headerText="{i18n>pendingMembersList}" class="sapUiMediumMarginTop">
					<Table items="{adminData>/pendingMembers}" noDataText="{i18n>noPendingMembers}"
						autoPopinMode="true" fixedLayout="false">
						<columns>
							<Column>
								<Text text="{i18n>fullName}" />
							</Column>
							<Column minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
								<Text text="{i18n>email}" />
							</Column>
							<Column minScreenWidth="Desktop" demandPopin="true" popinDisplay="Inline">
								<Text text="{i18n>createdAt}" />
							</Column>
							<Column hAlign="End">
								<Text text="{i18n>actions}" />
							</Column>
						</columns>
						<items>
							<ColumnListItem type="Navigation" press=".onMemberPress">
								<Text text="{adminData>firstName} {adminData>lastName}" />
								<Text text="{adminData>email}" />
								<Text text="{adminData>createdAtFormatted}" />
								<Button text="{i18n>approve}" type="Accept" press=".onApproveMember" />
							</ColumnListItem>
						</items>
					</Table>
				</Panel>
			</VBox>
		</content>
	</Page>
</mvc:View>
