<mvc:View controllerName="com.openui5.webdb.controller.admin.AdminMedia"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core">

	<Page id="adminMediaPage" title="{i18n>adminMedia}" showNavButton="false" class="sapUiContentPadding">
		<content>
			<VBox>
				<OverflowToolbar>
					<Title text="{i18n>adminMedia}" level="H2" />
					<ToolbarSpacer />
					<Label text="Ad:" class="sapUiTinyMarginBegin" />
					<Input id="filterFirstName" width="8rem" placeholder="Üye Adı" liveChange=".onFilter" 
						showSuggestion="true" suggestionItems="{mediaPoolData>/suggestions/firstNames}">
						<suggestionItems>
							<core:Item text="{mediaPoolData>text}" />
						</suggestionItems>
					</Input>

					<Label text="Soyad:" class="sapUiTinyMarginBegin" />
					<Input id="filterLastName" width="8rem" placeholder="Soyadı" liveChange=".onFilter" 
						showSuggestion="true" suggestionItems="{mediaPoolData>/suggestions/lastNames}">
						<suggestionItems>
							<core:Item text="{mediaPoolData>text}" />
						</suggestionItems>
					</Input>

					<Label text="E-posta:" class="sapUiTinyMarginBegin" />
					<Input id="filterEmail" width="10rem" placeholder="E-posta" liveChange=".onFilter" 
						showSuggestion="true" suggestionItems="{mediaPoolData>/suggestions/emails}">
						<suggestionItems>
							<core:Item text="{mediaPoolData>text}" />
						</suggestionItems>
					</Input>

					<Label text="Dosya:" class="sapUiTinyMarginBegin" />
					<Label text="Durum:" class="sapUiTinyMarginBegin" />
					<Select id="filterStatus" change=".onFilter" width="10rem">
						<items>
							<core:Item key="all" text="Tümü" />
							<core:Item key="active" text="Aktif" />
							<core:Item key="inactive" text="Pasif" />
							<core:Item key="pending" text="Onay Bekliyor" />
						</items>
					</Select>
				</OverflowToolbar>
				<ScrollContainer vertical="true" horizontal="false" height="100%">
					<FlexBox id="adminMediaGallery" wrap="Wrap" items="{mediaPoolData>/media}" justifyContent="Start" alignItems="Start" class="sapUiSmallMargin">
						<items>
							<VBox class="sapUiMediumMarginEnd sapUiMediumMarginBottom" width="320px" alignItems="Center">
								<Image src="{mediaPoolData>fileData}" height="240px" 
									press=".onImagePress" densityAware="false" 
									class="sapUiSystemPointer" />
								<VBox class="sapUiTinyMarginTop">
									<Label text="{mediaPoolData>fileName}" design="Bold" />
									<HBox>
										<Text text="Üye: " />
										<Link text="{mediaPoolData>memberName}" press=".onMemberPress" class="sapUiTinyMarginBegin" />
									</HBox>
									<ObjectStatus text="{mediaPoolData>memberStatusText}" state="{mediaPoolData>statusState}" />
									<Text text="Tarih: {mediaPoolData>createdAtFormatted}" />
									<Button icon="sap-icon://delete" type="Reject" press=".onDeleteMedia" class="sapUiTinyMarginTop" text="Sil" />
								</VBox>
							</VBox>
						</items>
					</FlexBox>
				</ScrollContainer>
			</VBox>
		</content>
	</Page>
</mvc:View>
