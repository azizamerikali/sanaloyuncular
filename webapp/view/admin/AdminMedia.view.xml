<mvc:View controllerName="com.openui5.webdb.controller.admin.AdminMedia"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core">

	<Page id="adminMediaPage" title="{i18n>adminMedia}" showNavButton="false" class="sapUiContentPadding">
		<content>
			<VBox>
				<OverflowToolbar>
					<Title text="{i18n>adminMedia}" level="H2" />
					<ToolbarSpacer />
					<SearchField width="15rem" placeholder="Arama (Üye veya Dosya)" search=".onSearch" liveChange=".onSearch" />
				</OverflowToolbar>
				<ScrollContainer vertical="true" horizontal="false" height="100%">
					<FlexBox id="adminMediaGallery" wrap="Wrap" items="{mediaPoolData>/media}" justifyContent="Start" alignItems="Start" class="sapUiSmallMargin">
						<items>
							<VBox class="sapUiMediumMarginEnd sapUiMediumMarginBottom" width="320px" alignItems="Center">
								<Image src="{mediaPoolData>fileData}" height="240px" 
									press=".onImagePress" densityAware="false" 
									class="sapUiSystemPointer" />
								<VBox class="sapUiTinyMarginTop">
									<Label text="{mediaPoolData>fileName}" design="Bold" />
									<Text text="Üye: {mediaPoolData>memberName}" />
									<Text text="Tarih: {mediaPoolData>createdAtFormatted}" />
									<Button icon="sap-icon://delete" type="Reject" press=".onDeleteMedia" class="sapUiTinyMarginTop" text="Sil" />
								</VBox>
							</VBox>
						</items>
					</FlexBox>
				</ScrollContainer>
			</VBox>
		</content>
	</Page>
</mvc:View>
