<mvc:View controllerName="com.openui5.webdb.controller.admin.AdminClients"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core"
	xmlns:f="sap.f" xmlns:cssgrid="sap.ui.layout.cssgrid">

	<Page id="adminClientsPage" title="{i18n>adminClients}" showNavButton="false" class="sapUiContentPadding">
		<headerContent>
			<Button text="{i18n>createClient}" icon="sap-icon://add" type="Emphasized"
				press=".onCreateClient" />
		</headerContent>
		<content>
			<f:GridList items="{clientData>/clients}"
				noDataText="{i18n>noClients}"
				growing="true" growingThreshold="20"
				showSeparators="None"
				class="soMemberGrid sapUiNoContentPadding">
				<f:customLayout>
					<cssgrid:GridBoxLayout boxMinWidth="280px" />
				</f:customLayout>
				<f:GridListItem type="Inactive">
					<VBox class="soMemberCard">
						<HBox justifyContent="SpaceBetween" alignItems="Start">
							<HBox alignItems="Center" class="sapUiSmallMarginBottom">
								<Avatar
									initials="{clientData>initials}"
									displaySize="M"
									displayShape="Circle"
									fallbackIcon="sap-icon://person-placeholder"
									class="sapUiSmallMarginEnd" />
								<VBox>
									<Title text="{clientData>firstName} {clientData>lastName}"
										level="H5" class="soMemberCardName" />
									<Text text="{clientData>email}" class="soMemberCardEmail" />
									<Text text="{clientData>phone}" class="soMemberCardEmail" />
								</VBox>
							</HBox>
							<ObjectStatus text="{clientData>statusText}" state="{clientData>statusState}" />
						</HBox>
						<core:HTML content="&lt;hr class='soCardDivider'/&gt;" />
						<HBox justifyContent="End">
							<Button icon="sap-icon://delete" type="Reject"
								press=".onDeleteClient" tooltip="Sil" />
						</HBox>
					</VBox>
				</f:GridListItem>
			</f:GridList>
		</content>
	</Page>
</mvc:View>
