<mvc:View controllerName="com.openui5.webdb.controller.admin.AdminProjects"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core"
	xmlns:f="sap.f" xmlns:cssgrid="sap.ui.layout.cssgrid">

	<Page id="adminProjectsPage" title="{i18n>adminProjects}" showNavButton="false" class="sapUiContentPadding">
		<headerContent>
			<Button text="{i18n>createProject}" icon="sap-icon://add" type="Emphasized"
				press=".onCreateProject" />
		</headerContent>
		<content>
			<f:GridList id="adminProjectsGrid" items="{projListData>/projects}"
				noDataText="{i18n>noProjects}"
				growing="true" growingThreshold="20"
				showSeparators="None"
				class="soProjectGrid sapUiNoContentPadding">
				<f:customLayout>
					<cssgrid:GridBoxLayout boxMinWidth="300px" />
				</f:customLayout>
				<f:GridListItem type="Active" press=".onProjectPress">
					<VBox class="soProjectCard">
						<HBox justifyContent="SpaceBetween" alignItems="Start" class="sapUiSmallMarginBottom">
							<Title text="{projListData>name}" level="H5" class="soProjectTitle" />
							<ObjectStatus text="{projListData>statusText}" state="{projListData>statusState}" />
						</HBox>
						<Text text="{projListData>description}" class="soProjectDesc" />
						<core:HTML content="&lt;hr class='soCardDivider'/&gt;" />
						<HBox justifyContent="SpaceBetween" alignItems="Center">
							<HBox alignItems="Center" wrap="Wrap">
								<core:Icon src="sap-icon://group" class="sapUiTinyMarginEnd soMemberCardEmail" />
								<Text text="{projListData>membersLabel}" class="soMemberCardEmail sapUiSmallMarginEnd" />
								<core:Icon src="sap-icon://money-bills" class="sapUiTinyMarginEnd soMemberCardEmail" />
								<Text text="{projListData>budgetFormatted}" class="soMemberCardEmail sapUiSmallMarginEnd" />
								<Text text="{projListData>createdAtFormatted}" class="soMemberCardEmail" />
							</HBox>
							<Button icon="sap-icon://delete" type="Reject"
								press=".onDeleteProject" tooltip="Sil" />
						</HBox>
					</VBox>
				</f:GridListItem>
			</f:GridList>
		</content>
	</Page>
</mvc:View>
