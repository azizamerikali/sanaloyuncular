<mvc:View
	controllerName="com.openui5.webdb.controller.admin.AdminSystem"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:layout="sap.ui.layout"
	xmlns:unified="sap.ui.unified"
	xmlns:core="sap.ui.core">

	<Page title="{i18n>systemManagement}" showNavButton="false" class="sapUiContentPadding">
		<content>
			<VBox spacing="1rem">
				
				<Panel headerText="{i18n>dbBackupRestore}" class="sapUiResponsiveMargin">
					<VBox spacing="Medium">
						<HBox alignItems="Center">
							<core:Icon src="sap-icon://status-completed" color="Positive" size="2rem" class="sapUiSmallMarginEnd" />
							<VBox>
								<Title text="{i18n>downloadDbBackup}" level="H3" />
								<Text text="{i18n>downloadDbBackupDesc}" />
							</VBox>
						</HBox>
						<Button text="{i18n>downloadBackupBtn}" icon="sap-icon://download" type="Emphasized" press=".onDownloadBackup" width="200px" />
						
						<VBox class="sapUiMediumMarginTopBottom" />

						<HBox alignItems="Center">
							<core:Icon src="sap-icon://upload-to-cloud" color="Critical" size="2rem" class="sapUiSmallMarginEnd" />
							<VBox>
								<Title text="{i18n>uploadDbBackup}" level="H3" />
								<Text text="{i18n>uploadDbBackupDesc}" />
							</VBox>
						</HBox>
						
						<layout:VerticalLayout>
							<unified:FileUploader
								id="dbFileUploader"
								name="backup"
								fileType="json"
								placeholder="{i18n>selectBackupFile}"
								style="Emphasized"
								width="400px"
								change=".onFileChange" />
							
							<CheckBox id="confirmRestore" text="{i18n>confirmOverwrite}" select=".onConfirmationChange" class="sapUiSmallMarginTop" />
							
							<Button 
								id="restoreButton"
								text="{i18n>restoreBackupBtn}" 
								icon="sap-icon://refresh" 
								type="Negative" 
								press=".onRestoreBackup" 
								enabled="false"
								class="sapUiSmallMarginTop"
								width="200px" />
						</layout:VerticalLayout>
					</VBox>
				</Panel>

			</VBox>
		</content>
	</Page>

</mvc:View>
