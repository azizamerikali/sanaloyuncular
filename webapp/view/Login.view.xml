<mvc:View
	controllerName="com.openui5.webdb.controller.Login"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core">

	<Page id="loginPage" showHeader="false" class="antigravityLoginBg">
		<content>
			<FlexBox alignItems="Center" justifyContent="Center" height="100%" width="100%"
				fitContainer="true" direction="Column">

				<VBox class="soLoginContainer">
					<!-- Header Section (Centered) -->
					<VBox alignItems="Center" width="100%">
						<core:Icon src="sap-icon://photo-voltaic" class="soLoginLogo" />
						<Title text="{i18n>appTitle}" class="soLoginTitle sapUiTinyMarginBottom" />
						<Text text="{i18n>loginSubtitle}" class="soLoginSubtitle sapUiMediumMarginBottom" />
					</VBox>

					<!-- Form Section -->
					<VBox width="100%" class="sapUiLargeMarginTop">
						<Title text="Müşteri Girişi" class="soLoginSectionTitle sapUiSmallMarginBottom" />
						
						<Label text="Kullanıcı Adı" labelFor="usernameInput" />
						<Input id="usernameInput" class="sapUiSmallMarginBottom" width="100%" valueLiveUpdate="true" />

						<Label text="Şifre" labelFor="passwordInput" />
						<Input id="passwordInput" type="Password" class="sapUiMediumMarginBottom" width="100%" valueLiveUpdate="true" />

						<Button text="Giriş Yap" type="Emphasized" width="100%" 
							press=".onLoginPress" class="soLoginBtn sapUiSmallMarginBottom" />

						<!-- Divider -->
						<core:HTML content="&lt;div class='soLoginDivider'&gt;Veya&lt;/div&gt;" />

						<!-- Google Login -->
						<core:HTML content='&lt;div id="googleButtonContainer" class="sapUiSmallMarginBottom" style="display:flex; justify-content:center; width:100%;"&gt;&lt;/div&gt;' />
					</VBox>
				</VBox>

			</FlexBox>
		</content>
	</Page>

</mvc:View>
