<mvc:View controllerName="com.openui5.webdb.controller.client.ClientMembers"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core"
	xmlns:f="sap.f" xmlns:cssgrid="sap.ui.layout.cssgrid">

	<Page id="clientMembersPage" title="{i18n>clientMembers}" showNavButton="false" class="sapUiContentPadding">
		<dependents>
			<Dialog id="memberDetailDialog" title="Fotoğraflar" contentWidth="620px" contentHeight="520px" draggable="true" resizable="true">
				<content>
					<core:HTML id="memberPhotosHtml" content="&lt;div id='so-member-slider' style='width:100%;height:440px;display:flex;align-items:center;justify-content:center;background:#000;border-radius:8px;overflow:hidden;position:relative'&gt;&lt;img id='so-member-img' src='' style='max-width:100%;max-height:440px;width:auto;height:auto;object-fit:contain;display:block;border-radius:8px;transition:opacity 0.3s ease'/&gt;&lt;button onclick='window.soMemberPrev()' style='position:absolute;left:8px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.5);color:#fff;border:none;border-radius:50%;width:36px;height:36px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center'&gt;&amp;lt;&lt;/button&gt;&lt;button onclick='window.soMemberNext()' style='position:absolute;right:8px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.5);color:#fff;border:none;border-radius:50%;width:36px;height:36px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center'&gt;&amp;gt;&lt;/button&gt;&lt;div style='position:absolute;bottom:8px;right:12px;display:flex;align-items:center;gap:6px'&gt;&lt;button onclick='window.soMemberDownload()' title='Fotoğrafı İndir' style='background:rgba(0,0,0,0.55);color:#fff;border:none;border-radius:50%;width:30px;height:30px;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0'&gt;&lt;svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;16&quot; height=&quot;16&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; stroke-width=&quot;2&quot; stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot;&gt;&lt;path d=&quot;M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4&quot;/&gt;&lt;polyline points=&quot;7 10 12 15 17 10&quot;/&gt;&lt;line x1=&quot;12&quot; y1=&quot;15&quot; x2=&quot;12&quot; y2=&quot;3&quot;/&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div id='so-member-counter' style='background:rgba(0,0,0,0.55);color:#fff;font-size:12px;padding:2px 8px;border-radius:12px'&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" />
					<VBox id="memberNoPhotosBox" visible="false" alignItems="Center" justifyContent="Center" class="sapUiLargeMargin">
						<core:Icon src="sap-icon://attachment-photo" size="3rem" color="#ccc" class="sapUiSmallMarginBottom" />
						<Title text="{i18n>noPhotosForMember}" level="H3" />
					</VBox>
				</content>
				<buttons>
					<Button text="{i18n>close}" press=".onCloseMemberDetail" />
				</buttons>
			</Dialog>
		</dependents>
		<content>
			<f:GridList items="{cMembersData>/members}"
				noDataText="{i18n>noMembers}"
				growing="true" growingThreshold="20"
				showSeparators="None"
				class="soMemberGrid sapUiNoContentPadding">
				<f:customLayout>
					<cssgrid:GridBoxLayout boxMinWidth="300px" />
				</f:customLayout>
				<f:GridListItem>
					<VBox class="soMemberCard" height="100%" justifyContent="SpaceBetween">
						<VBox>
							<HBox justifyContent="SpaceBetween" alignItems="Start" class="sapUiSmallMarginBottom">
								<HBox alignItems="Center">
									<Avatar src="{path: 'cMembersData>profilePicture', formatter: '.formatProfilePicture'}" initials="{cMembersData>initials}" displaySize="M" displayShape="Circle" fallbackIcon="sap-icon://person-placeholder" class="sapUiSmallMarginEnd soMemberAvatar" />
									<VBox>
										<Title text="{cMembersData>firstName} {cMembersData>lastName}" level="H4" class="soMemberCardName sapUiTinyMarginBottom" />
										<HBox alignItems="Center">
											<core:Icon src="sap-icon://email" size="0.8rem" color="#767683" class="sapUiTinyMarginEnd" />
											<Text text="{cMembersData>email}" class="soMemberCardEmail" />
										</HBox>
									</VBox>
								</HBox>
								<Button icon="{= ${cMembersData>isFavorite} ? 'sap-icon://favorite' : 'sap-icon://unfavorite'}" 
									type="Transparent" 
									press=".onToggleFavorite" 
									class="{= ${cMembersData>isFavorite} ? 'soStarButtonActive' : 'soStarButton'}" />
							</HBox>
						</VBox>
						
						<VBox>
							<core:HTML content="&lt;hr class='soCardDivider'/&gt;" />
							<HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginTop">
								<HBox alignItems="Center">
									<core:Icon src="sap-icon://photo-voltaic" size="1.2rem" color="#767683" class="sapUiSmallMarginEnd" />
									<Text text="{= ${cMembersData>photoCount} + ' Fotoğraf'}" class="soPhotoCountText" />
								</HBox>
								<Link text="{i18n>details}" press=".onNavigateToMemberDetail" class="soDetailLink" />
							</HBox>
						</VBox>
					</VBox>
				</f:GridListItem>
			</f:GridList>
		</content>
	</Page>
</mvc:View>
