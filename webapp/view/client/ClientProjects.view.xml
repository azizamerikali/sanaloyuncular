<mvc:View controllerName="com.openui5.webdb.controller.client.ClientProjects"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core"
	xmlns:f="sap.f" xmlns:cssgrid="sap.ui.layout.cssgrid">

	<Page id="clientProjectsPage" title="{i18n>clientProjects}" showNavButton="false" class="sapUiContentPadding">
		<headerContent>
			<Button text="{i18n>createProject}" icon="sap-icon://add" type="Emphasized"
				press=".onCreateProject" />
		</headerContent>
		<content>
			<f:GridList items="{cProjData>/projects}"
				noDataText="{i18n>noProjects}"
				growing="true" growingThreshold="20"
				showSeparators="None"
				class="soProjectGrid sapUiNoContentPadding">
				<f:customLayout>
					<cssgrid:GridBoxLayout boxMinWidth="300px" />
				</f:customLayout>
				<f:GridListItem type="Active" press=".onProjectPress">
					<VBox class="soProjectCard">
						<HBox justifyContent="SpaceBetween" alignItems="Start" class="sapUiSmallMarginBottom">
							<Title text="{cProjData>name}" level="H5" class="soProjectTitle" />
							<ObjectStatus text="{cProjData>statusText}" state="{cProjData>statusState}" />
						</HBox>
						<Text text="{cProjData>description}" class="soProjectDesc" />
						<core:HTML content="&lt;hr class='soCardDivider'/&gt;" />
						<HBox alignItems="Center" wrap="Wrap">
							<core:Icon src="sap-icon://group" class="sapUiTinyMarginEnd soMemberCardEmail" />
							<Text text="{cProjData>membersLabel}" class="soMemberCardEmail sapUiSmallMarginEnd" />
							<core:Icon src="sap-icon://money-bills" class="sapUiTinyMarginEnd soMemberCardEmail" />
							<Text text="{cProjData>budgetFormatted}" class="soMemberCardEmail sapUiSmallMarginEnd" />
							<Text text="{cProjData>createdAtFormatted}" class="soMemberCardEmail" />
						</HBox>
					</VBox>
				</f:GridListItem>
			</f:GridList>
		</content>
	</Page>
</mvc:View>
