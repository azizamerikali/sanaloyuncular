<mvc:View
	controllerName="com.openui5.webdb.controller.App"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:tnt="sap.tnt"
	xmlns:core="sap.ui.core">

	<tnt:ToolPage id="toolPage" sideExpanded="{appView>/sideExpanded}">
		<tnt:header>
			<tnt:ToolHeader visible="{appView>/showShell}">
				<Button
					id="sideNavToggle"
					icon="sap-icon://menu2"
					type="Transparent"
					tooltip="{i18n>menuToggle}"
					press=".onToggleSideNav" />
				<Title text="{i18n>appTitle}" level="H4" class="sapUiSmallMarginBegin soHeaderTitleFull" />
				<Title text="SO" level="H4" class="sapUiSmallMarginBegin soHeaderTitleShort" />
				<ToolbarSpacer />
				<Avatar
					id="userAvatar"
					displaySize="XS"
					displayShape="Circle"
					src="{appView>/userProfilePicture}"
					initials="{appView>/userInitials}"
					backgroundColor="Accent6" />
				<Text
					text="{appView>/currentUserEmail}"
					wrapping="false"
					tooltip="{appView>/currentUserEmail}"
					class="sapUiSmallMarginBegin soHeaderEmail" />
				<Button
					id="logoutBtn"
					icon="sap-icon://log"
					type="Transparent"
					tooltip="{i18n>logout}"
					press=".onLogout" />
			</tnt:ToolHeader>
		</tnt:header>

		<tnt:sideContent>
			<tnt:SideNavigation
				id="sideNav"
				visible="{appView>/showShell}"
				selectedKey="{appView>/selectedKey}"
				itemSelect=".onNavItemSelect">
				<tnt:NavigationList id="navList" />
				<tnt:fixedItem>
					<tnt:NavigationList>
						<tnt:NavigationListItem
							text="{i18n>logout}"
							icon="sap-icon://log"
							key="logout" />
					</tnt:NavigationList>
				</tnt:fixedItem>
			</tnt:SideNavigation>
		</tnt:sideContent>

		<tnt:mainContents>
			<NavContainer id="pageContainer" />
		</tnt:mainContents>
	</tnt:ToolPage>

</mvc:View>
