<mvc:View controllerName="com.openui5.webdb.controller.member.MemberProfile"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core">

	<Page id="memberProfilePage" title="{i18n>memberProfile}" showNavButton="false" class="sapUiContentPadding">
		<content>
			<VBox>
				<Panel headerText="{i18n>memberProfile}">
					<VBox alignItems="Center" class="sapUiMediumMarginBottom">
						<Avatar src="{profileData>/profilePicture}" displaySize="XL" displayShape="Circle" backgroundColor="Accent6" class="sapUiSmallMarginBottom" />
						<Button text="{i18n>changePhoto}" icon="sap-icon://camera" press=".onUploadPress" />
					</VBox>
					<f:SimpleForm id="profileForm" editable="true" layout="ResponsiveGridLayout"
						labelSpanXL="3" labelSpanL="4" labelSpanM="4" labelSpanS="12"
						columnsXL="1" columnsL="1" columnsM="1">

						<Label text="{i18n>firstName}" required="true" />
						<Input id="profileFirstName" value="{profileData>/firstName}" />

						<Label text="{i18n>lastName}" required="true" />
						<Input id="profileLastName" value="{profileData>/lastName}" />

						<Label text="{i18n>email}" />
						<Input id="profileEmail" value="{profileData>/email}" type="Email" />

						<Label text="{i18n>phone}" />
						<Input id="profilePhone" value="{profileData>/phone}" type="Tel" />

						<Label text="{i18n>address}" />
						<TextArea id="profileAddress" value="{profileData>/address}" rows="3" />

						<Label text="{i18n>status}" />
						<ObjectStatus text="{profileData>/statusText}" state="{profileData>/statusState}" />

						<Label text="{i18n>createdAt}" />
						<Text text="{profileData>/createdAtFormatted}" />
					</f:SimpleForm>

					<Toolbar>
						<ToolbarSpacer />
						<Button text="{i18n>save}" type="Emphasized" icon="sap-icon://save"
							press=".onSaveProfile" />
					</Toolbar>
				</Panel>
			</VBox>
		</content>
		<dependents>
			<ActionSheet id="uploadActionSheet" title="{i18n>photoSelection}" showCancelButton="true" cancelButtonText="{i18n>cancel}">
				<buttons>
					<Button text="{i18n>takeWithCamera}" icon="sap-icon://camera" press=".onCameraCapture" />
					<Button text="{i18n>selectFromGallery}" icon="sap-icon://attachment-photo" press=".onGallerySelect" />
				</buttons>
			</ActionSheet>

			<Dialog id="cameraDialog" title="{i18n>takePhotoWithCamera}"
				contentWidth="520px" contentHeight="420px"
				afterOpen=".onCameraDialogAfterOpen"
				afterClose=".onCameraDialogAfterClose">
				<content>
					<VBox alignItems="Center" justifyContent="Center" width="100%" class="sapUiContentPadding">
						<core:HTML id="cameraHtml"
							content="&lt;div style='position:relative;width:100%;text-align:center'&gt;&lt;video id='so-profile-video' autoplay playsinline muted style='width:100%;max-width:480px;max-height:320px;border-radius:8px;background:#000'&gt;&lt;/video&gt;&lt;canvas id='so-profile-canvas' style='display:none'&gt;&lt;/canvas&gt;&lt;/div&gt;" />
					</VBox>
				</content>
				<buttons>
					<Button id="captureBtn" text="{i18n>takePhotoAction}" icon="sap-icon://camera" type="Emphasized" press=".onCapturePhoto" />
					<Button text="{i18n>cancel}" press=".onCloseCamera" />
				</buttons>
			</Dialog>
		</dependents>
	</Page>
</mvc:View>
