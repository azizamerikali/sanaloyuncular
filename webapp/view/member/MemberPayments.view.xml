<mvc:View controllerName="com.openui5.webdb.controller.member.MemberPayments"
	xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc">

	<Page id="memberPaymentsPage" title="{i18n>memberPayments}" showNavButton="false" class="sapUiContentPadding">
		<content>
			<Table id="memberPaymentsTable" items="{payData>/payments}"
				noDataText="{i18n>noPayments}"
				growing="true" growingThreshold="20">
				<columns>
					<Column>
						<Text text="{i18n>projectName}" />
					</Column>
					<Column hAlign="End" minScreenWidth="Phone">
						<Text text="{i18n>grossAmount}" />
					</Column>
					<Column hAlign="End" minScreenWidth="Desktop" demandPopin="true" popinDisplay="Inline">
						<Text text="{i18n>deduction}" />
					</Column>
					<Column hAlign="End" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
						<Text text="{i18n>netAmount}" />
					</Column>
					<Column minScreenWidth="Phone">
						<Text text="{i18n>paymentStatus}" />
					</Column>
					<Column minScreenWidth="Desktop" demandPopin="true" popinDisplay="Inline">
						<Text text="{i18n>paymentDate}" />
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<Text text="{payData>projectName}" />
						<Text text="{payData>grossFormatted}" />
						<Text text="{payData>deductionFormatted}" />
						<Text text="{payData>netFormatted}" />
						<ObjectStatus text="{payData>statusText}" state="{payData>statusState}" />
						<Text text="{payData>date}" />
					</ColumnListItem>
				</items>
			</Table>
		</content>
	</Page>
</mvc:View>
