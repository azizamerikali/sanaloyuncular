{
	"name": "com.openui5.webdb",
	"version": "1.0.0",
	"description": "UI5 Application: com.openui5.webdb",
	"author": "devaziz",
	"license": "Apache-2.0",
	"scripts": {
		"clean": "rimraf dist coverage",
		"build": "ui5 build --clean-dest --dest ./public",
		"build:opt": "ui5 build self-contained --clean-dest --all --dest ./public",
		"start": "ui5 serve --port 8080 -o index.html",
		"start-cdn": "ui5 serve --port 8080 -o index-cdn.html",
		"start-coverage": "ui5 serve --port 8080 --config ui5-coverage.yaml",
		"start:dist": "npm start -- --config ui5-dist.yaml",
		"start:dist-cdn": "npm run start-cdn -- --config ui5-dist.yaml",
		"ts-typecheck": "tsc --noEmit",
		"lint": "eslint webapp",
		"ui5lint": "ui5lint",
		"test-runner": "ui5-test-runner --url http://localhost:8080/test/testsuite.qunit.html",
		"test-runner-coverage": "ui5-test-runner --url http://localhost:8080/test/testsuite.qunit.html --coverage -ccb 50 -ccf 50 -ccl 50 -ccs 50",
		"test-ui5": "ui5-test-runner --start start-coverage --url http://localhost:8080/test/testsuite.qunit.html --coverage -ccb 50 -ccf 50 -ccl 50 -ccs 50",
		"test": "npm run lint && npm run test-ui5",
		"wdi5": "wdio run ./webapp/test/e2e/\\wdio.conf.ts"
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.5",
		"dotenv": "^17.4.1",
		"express": "^4.21.2",
		"express-rate-limit": "^8.3.2",
		"google-auth-library": "^10.6.2",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.3",
		"multer": "^2.1.1",
		"sql.js": "^1.11.0"
	},
	"devDependencies": {
		"@openui5/types": "^1.146.0",
		"@ui5/cli": "^4.0.26",
		"@ui5/linter": "^1.20.0",
		"@wdio/cli": "^9.27.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"babel-plugin-istanbul": "^7.0.1",
		"eslint": "^9.36.0",
		"globals": "^16.4.0",
		"rimraf": "^6.0.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.44.1",
		"ui5-middleware-livereload": "^3.1.4",
		"ui5-test-runner": "^5.9.1",
		"ui5-tooling-transpile": "^3.9.2",
		"wdio-ui5-service": "^3.0.8",
		"@types/bcryptjs": "^3.0.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^22.12.0"
	}
}
